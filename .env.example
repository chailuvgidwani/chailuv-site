# Contact form email delivery (optional).
# The /api/contact route works without these — it just logs the message
# and returns success. To actually deliver mail, sign up at resend.com,
# add these two vars in Vercel (Project → Settings → Environment Variables),
# and redeploy.
RESEND_API_KEY=
# Where contact-form submissions are delivered:
CONTACT_TO_EMAIL=chailuv@example.com
# Verified sender (a domain/address you own in Resend):
CONTACT_FROM_EMAIL=onboarding@resend.dev
